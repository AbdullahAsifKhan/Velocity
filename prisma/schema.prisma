generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  garage        GarageItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Car Showcase Models
model Car {
  id               String   @id @default(cuid())
  name             String
  brand            String
  type             String
  fuelType         String
  horsepower       Int
  torque           Int
  acceleration     Float
  topSpeed         Int
  mileage          String?
  engine           String?
  price            Int
  year             Int
  drivetrain       String?
  transmission     String?
  seats            Int?
  doors            Int?
  weight           Int?
  fuelTankCapacity String?
  length           Int?    // in mm
  width            Int?    // in mm
  height           Int?    // in mm
  wheelbase        Int?    // in mm
  groundClearance  Int?    // in mm
  aerodynamics     String? // e.g. "0.24 Cd"
  suspension       String?
  brakes           String?
  tires            String?
  infotainment     String?
  safetyFeatures   String?
  driveModes       String?
  emissions        String?
  country          String?
  launchDate       String?
  image            String
  rating           Float?  @default(0.0)
  
  // Legacy / Additional fields
  views            Int     @default(0)
  favorites        Int     @default(0)
  featured         Boolean @default(false)
  description      String
  specSheetUrl     String?
  officialPageUrl  String?

  // Relations
  images           CarGalleryImage[]
  sources          CarSource[]
  garagedBy        GarageItem[]
}

model CarGalleryImage {
  id    String @id @default(cuid())
  url   String
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model CarSource {
  id          String   @id @default(cuid())
  sourceId    String
  sourceName  String
  url         String?
  retrievedAt DateTime @default(now())
  
  carId       String
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model GarageItem {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  addedAt   DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}
