generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  garage        GarageItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Car Showcase Models
model Car {
  id               String   @id @default(cuid())
  name             String
  brand            String
  type             String
  fuelType         String
  horsepower       Int
  torque           Int
  acceleration     Float
  topSpeed         Int
  mileage          String?
  engine           String?
  price            Int
  priceNote        String?
  year             Int
  drivetrain       String?
  transmission     String?
  seats            Int?
  doors            Int?
  weight           Int?
  fuelTankCapacity String?
  length           Int?    // in mm
  width            Int?    // in mm
  height           Int?    // in mm
  wheelbase        Int?    // in mm
  groundClearance  Int?    // in mm
  aerodynamics     String? // e.g. "0.24 Cd"
  suspension       String?
  brakes           String?
  tires            String?
  infotainment     String?
  safetyFeatures   String?
  driveModes       String?
  emissions        String?
  country          String?
  launchDate       String?
  image            String
  cdnImage         String? // Stored fallback URL on Cloudflare R2
  rating           Float?  @default(0.0)
  
  // Legacy / Additional fields
  views            Int     @default(0)
  favorites        Int     @default(0)
  featured         Boolean @default(false)
  description      String
  specSheetUrl     String?
  officialPageUrl  String?

  // Model family grouping — groups variants of the same physical car
  modelFamily      String?               // e.g. "RAV4" groups RAV4 LE, RAV4 Prime, Vanguard, etc.
  isCanonical      Boolean @default(false) // true = the "display" variant shown in the brand grid
  
  // Scoring and filtering
  popularityScore  Float   @default(0.0)
  platformScore    Float   @default(0.0)
  blendedScore     Float   @default(0.0)
  isDemoted        Boolean @default(false)
  dateAdded        DateTime @default(now())

  // Relations
  images           CarGalleryImage[]
  sources          CarSource[]
  garagedBy        GarageItem[]
  errorReports     ErrorReport[]
  carViews         CarView[]
  carImpressions   CarImpression[]

  @@index([brand, modelFamily, isCanonical])
  @@index([blendedScore(sort: Desc)])
}

model CarGalleryImage {
  id    String @id @default(cuid())
  url   String
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model CarSource {
  id          String   @id @default(cuid())
  sourceId    String
  sourceName  String
  url         String?
  retrievedAt DateTime @default(now())
  
  carId       String
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model GarageItem {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  addedAt   DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model ErrorReport {
  id          String   @id @default(cuid())
  carId       String
  category    String   // "wrong_specs", "wrong_image", "wrong_name", "other"
  description String
  evidence    String?  // optional URL or link to correct source
  ipHash      String   // hashed IP for rate-limit tracking (privacy-safe)
  status      String   @default("pending") // "pending", "reviewed", "resolved", "dismissed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

// ── Behavioral Tracking Models ──────────────────────────────────────────────

/// Timestamped car page views (per anonymous session) — used for trending score
model CarView {
  id        String   @id @default(cuid())
  carId     String
  sessionId String
  viewedAt  DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, viewedAt])
  @@index([sessionId, viewedAt])
}

/// Co-view pair counts — "users who viewed A also viewed B"
model CarCoView {
  id     String @id @default(cuid())
  carAId String
  carBId String
  count  Int    @default(1)

  @@unique([carAId, carBId])
  @@index([carAId])
}

/// Card impressions — tracks when a car card is shown and whether it was clicked (for CTR)
model CarImpression {
  id          String   @id @default(cuid())
  carId       String
  sessionId   String
  clicked     Boolean  @default(false)
  impressedAt DateTime @default(now())
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, impressedAt])
}

