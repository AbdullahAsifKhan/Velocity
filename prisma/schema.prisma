generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  garage        GarageItem[]
  sessions      Session[]
  ratings       Rating[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Car {
  id                 String            @id @default(cuid())
  name               String
  brand              String
  type               String
  fuelType           String
  horsepower         Int
  torque             Int
  acceleration       Float
  topSpeed           Int
  mileage            String?
  engine             String?
  price              Int
  year               Int
  drivetrain         String?
  transmission       String?
  seats              Int?
  doors              Int?
  weight             Int?
  fuelTankCapacity   String?
  length             Int?
  width              Int?
  height             Int?
  wheelbase          Int?
  groundClearance    Int?
  aerodynamics       String?
  suspension         String?
  brakes             String?
  tires              String?
  infotainment       String?
  safetyFeatures     String?
  driveModes         String?
  emissions          String?
  country            String?
  launchDate         String?
  image              String
  rating             Float?            @default(0.0)
  views              Int               @default(0)
  favorites          Int               @default(0)
  featured           Boolean           @default(false)
  description        String
  specSheetUrl       String?
  officialPageUrl    String?
  priceNote          String?
  isCanonical        Boolean           @default(false)
  modelFamily        String?
  cdnImage           String?
  isDemoted          Boolean           @default(false)
  popularityScore    Float             @default(0.0)
  blendedScore       Float             @default(0.0)
  dateAdded          DateTime          @default(now())
  platformScore      Float             @default(0.0)
  bodyStyle          String?
  classifyConfidence Float?            @default(0.0)
  faceliftYear       Int?
  generation         String?
  generationEnd      Int?
  generationStart    Int?
  variantType        String?
  cleanName          String?
  images             CarGalleryImage[]
  carImpressions     CarImpression[]
  relationshipsOut   CarRelationship[] @relation("source")
  relationshipsIn    CarRelationship[] @relation("target")
  sources            CarSource[]
  carViews           CarView[]
  errorReports       ErrorReport[]
  garagedBy          GarageItem[]
  ratings            Rating[]

  @@index([brand, modelFamily, isCanonical])
  @@index([blendedScore(sort: Desc)])
  @@index([isCanonical, isDemoted, horsepower, blendedScore(sort: Desc)])
  @@index([brand, isDemoted, type])
  @@index([type])
  @@index([popularityScore(sort: Desc)])
  @@index([brand, modelFamily, generation])
  @@index([classifyConfidence])
}

model CarGalleryImage {
  id             String  @id @default(cuid())
  url            String
  carId          String
  priority       Int     @default(50)
  source         String  @default("wiki")
  isHeroImage    Boolean @default(false)
  perceptualHash String?
  isSharedImage  Boolean @default(false)
  car            Car     @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, priority])
  @@index([perceptualHash])
}

model CarRelationship {
  id               String  @id @default(cuid())
  sourceCarId      String
  targetCarId      String
  relationshipType String
  note             String?
  sourceCar        Car     @relation("source", fields: [sourceCarId], references: [id], onDelete: Cascade)
  targetCar        Car     @relation("target", fields: [targetCarId], references: [id], onDelete: Cascade)

  @@unique([sourceCarId, targetCarId, relationshipType])
  @@index([sourceCarId])
  @@index([targetCarId])
}

model CarSource {
  id          String   @id @default(cuid())
  sourceId    String
  sourceName  String
  url         String?
  retrievedAt DateTime @default(now())
  carId       String
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model GarageItem {
  id      String   @id @default(cuid())
  userId  String
  carId   String
  addedAt DateTime @default(now())
  car     Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model ErrorReport {
  id          String   @id @default(cuid())
  carId       String
  category    String
  description String
  evidence    String?
  ipHash      String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

/// Timestamped car page views (per anonymous session) — used for trending score
model CarView {
  id        String   @id @default(cuid())
  carId     String
  sessionId String
  viewedAt  DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, viewedAt])
  @@index([sessionId, viewedAt])
}

/// Co-view pair counts — "users who viewed A also viewed B"
model CarCoView {
  id     String @id @default(cuid())
  carAId String
  carBId String
  count  Int    @default(1)

  @@unique([carAId, carBId])
  @@index([carAId])
}

/// Card impressions — tracks when a car card is shown and whether it was clicked (for CTR)
model CarImpression {
  id          String   @id @default(cuid())
  carId       String
  sessionId   String
  clicked     Boolean  @default(false)
  impressedAt DateTime @default(now())
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, impressedAt])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
  @@index([carId])
}
