# ── Database (Neon PostgreSQL) ──────────────────────────────────────
# Use the POOLED connection string (hostname: *-pooler.*.neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Use the DIRECT connection string for migrations only
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ── External APIs ──────────────────────────────────────────────────
API_NINJAS_KEY="your-api-ninjas-key"
GOOGLE_API_KEY="your-google-api-key"
GOOGLE_CX="your-google-custom-search-cx"

# ── Auth ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── On-Demand Revalidation ─────────────────────────────────────────
REVALIDATION_SECRET="generate-a-random-secret-here"

# ── Cron Jobs ──────────────────────────────────────────────────────
CRON_SECRET="generate-a-random-secret-here"
